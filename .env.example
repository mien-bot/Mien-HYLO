# Relay Server Configuration
# See relay/server.js for full details

# Server port (default: 3456)
PORT=3456

# AI provider: "anthropic" (default) or "openai"
AI_PROVIDER=anthropic

# Anthropic API key (direct API access)
ANTHROPIC_API_KEY=sk-ant-...

# Claude Code OAuth token (alternative to API key)
CLAUDE_CODE_OAUTH_TOKEN=

# OpenAI API key (only if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Disable bearer token auth (not recommended for production)
# AUTH=off

# Enable Cloudflare Tunnel for public HTTPS access
# TUNNEL=1

# Public URL override for Strava OAuth callback
RELAY_PUBLIC_URL=

# Strava OAuth credentials (for workout sync)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Hostname of your Metro (Expo dev bundler) tunnel ingress, used by the
# GET /expo QR-code redirect shim. Only needed if you're running the mobile
# app through a named Cloudflare tunnel — see docs/setup/mobile-tunnel.md
METRO_TUNNEL_HOST=metro.example.com
