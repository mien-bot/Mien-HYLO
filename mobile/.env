# Expo dev server config — picked up automatically by `expo start`.
#
# Tells Metro to publish manifest URLs as if its public address is the
# Cloudflare named tunnel, instead of the LAN-style `host:8081`. Without
# these, Expo Go on the phone tries to fetch the bundle from
# `http://metro.example.com:8081/...`, which fails because Cloudflare only
# exposes the tunnel over HTTPS on port 443.
#
# If you spin up a different tunnel hostname for your own dev setup, edit
# these three values — the rest of the toolchain reads them transparently.

EXPO_PACKAGER_PROXY_URL=https://metro.example.com
EXPO_MANIFEST_PROXY_URL=https://metro.example.com
REACT_NATIVE_PACKAGER_HOSTNAME=metro.example.com
